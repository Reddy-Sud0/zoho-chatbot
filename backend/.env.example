ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:8000/auth/callback
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_API_BASE=https://projectsapi.zoho.in/api/v3

# Gemini API key for the LangGraph agents (router, query, action)
GOOGLE_API_KEY=your_gemini_api_key

# SQLite (default) or PostgreSQL for production
DATABASE_URL=sqlite:///./zoho_chatbot.db

# Random secret ≥32 characters (used for session integrity)
SECRET_KEY=your_random_secret_key_minimum_32_characters_long

# Where the Next.js frontend is hosted (used in CORS + OAuth redirect)
FRONTEND_BASE_URL=http://localhost:3000

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
